# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Clerk Authentication Configuration
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/candid/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/candid/login"

# General Site config
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
CRON_SECRET="your-cron-secret"

# AI / LLM Configuration
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.3-70b-versatile"
OPENROUTER_API_KEY="sk-or-v1-..."
JINA_API_KEY="jina_..."
CANDID_EMBEDDING_MODEL="jina-embeddings-v2-base-en"

# External APIs
TMDB_API_KEY="your-tmdb-api-key"
PEXELS_API_KEY="your-pexels-api-key"
GOOGLE_API_KEY="your-google-api-key"

# Optional: only set this if running the FastAPI backend separately.
CANDID_API_URL="http://localhost:8000"
